# =============================================
# VELOUR Perfumería — Variables de entorno
# =============================================
# 1. Renombrá este archivo a ".env" (sin el .example)
# 2. Completá con tus datos de Gmail
# =============================================

# Tu cuenta de Gmail
GMAIL_USER=nahuel21ocampo@gmail.com

# App Password de Google (NO es tu contraseña normal)
# Cómo generarla: ver README.md sección "Configurar Gmail"
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Puerto del servidor (por defecto 3000)
PORT=3000
